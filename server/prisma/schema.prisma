// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum AdminRole {
  super_admin
  admin
}

enum BannerPosition {
  hero
  secondary
  promotional
}

enum ContactStatus {
  new
  read
  replied
  closed
}

enum SettingType {
  text
  image
  json
  boolean
}

model Admin {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  email     String    @unique @db.VarChar(150)
  password  String    @db.VarChar(255)
  role      AdminRole @default(admin)
  is_active Boolean   @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("admins")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(150)
  password  String   @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  address   String?  @db.Text
  is_active Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(120)
  description String?   @db.Text
  image       String?   @db.VarChar(500)
  is_active   Boolean   @default(true)
  sort_order  Int       @default(0)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model Product {
  id                  Int            @id @default(autoincrement())
  category_id         Int?
  name                String         @db.VarChar(200)
  slug                String         @unique @db.VarChar(220)
  description         String?        @db.Text
  short_description   String?        @db.VarChar(500)
  price               Decimal        @db.Decimal(10, 2)
  original_price      Decimal?       @db.Decimal(10, 2)
  discount_percent    Int            @default(0)
  weight              String?        @db.VarChar(50)
  sku                 String?        @unique @db.VarChar(100)
  stock               Int            @default(0)
  rating              Decimal        @default(5.0) @db.Decimal(2, 1)
  review_count        Int            @default(0)
  thumbnail           String?        @db.VarChar(500)
  benefits            Json?
  nutrition_facts     Json?
  storage_instructions String?       @db.Text
  is_featured         Boolean        @default(false)
  is_best_seller      Boolean        @default(false)
  is_active           Boolean        @default(true)
  meta_title          String?        @db.VarChar(200)
  meta_description    String?        @db.Text
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt
  category            Category?      @relation(fields: [category_id], references: [id], onDelete: Cascade)
  images              ProductImage[]

  @@map("products")
}

model ProductImage {
  id         Int      @id @default(autoincrement())
  product_id Int?
  image_url  String   @db.VarChar(500)
  alt_text   String?  @db.VarChar(200)
  sort_order Int      @default(0)
  is_primary Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  product    Product? @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Banner {
  id          Int            @id @default(autoincrement())
  title       String         @db.VarChar(200)
  subtitle    String?        @db.VarChar(300)
  description String?        @db.Text
  image       String?        @db.VarChar(500)
  cta_text    String?        @db.VarChar(100)
  cta_link    String?        @db.VarChar(300)
  position    BannerPosition @default(hero)
  sort_order  Int            @default(0)
  is_active   Boolean        @default(true)
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  @@map("banners")
}

model Testimonial {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  designation String?  @db.VarChar(150)
  location    String?  @db.VarChar(100)
  avatar      String?  @db.VarChar(500)
  review      String   @db.Text
  rating      Int      @default(5)
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("testimonials")
}

model FAQ {
  id         Int      @id @default(autoincrement())
  question   String   @db.VarChar(500)
  answer     String   @db.Text
  category   String   @default("general") @db.VarChar(100)
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("faqs")
}

model Contact {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(100)
  email       String?       @db.VarChar(150)
  phone       String?       @db.VarChar(20)
  subject     String?       @db.VarChar(200)
  message     String        @db.Text
  status      ContactStatus @default(new)
  admin_notes String?       @db.Text
  ip_address  String?       @db.VarChar(45)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@map("contacts")
}

model Setting {
  id         Int         @id @default(autoincrement())
  key        String      @unique @db.VarChar(100)
  value      String?     @db.Text
  type       SettingType @default(text)
  group      String?     @default("general") @db.VarChar(50)
  label      String?     @db.VarChar(150)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  @@map("settings")
}
